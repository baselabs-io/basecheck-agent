# macOS
.DS_Store
**/.DS_Store

# secrets / local config
.agent_token
/config.yaml

# control-pack signing key (dev key generated by scripts/generate-signing-key.sh)
# -- README.md stays tracked; only the generated key material is ignored.
.signing/*
!.signing/README.md

# local caches
.cache/
.gocache/
.gomodcache/
.gopath/

# local outputs
/output/
results-pending/
basecheck-output-*.json
/logs/

# local binaries
/agent
/basecheck-agent
/examples/siem-demo/demo.sqlite
/examples/siem-demo/events.jsonl
/examples/siem-demo/receiver-demo
bin/
build/
dist/

# release artifacts
release/

# local test/sql scratch
test-audit-query.sql

# backup files
*.bak
*.backup
*copy.*

# IDE
.idea/
.vscode/
*.swp

# build outputs
build/
config/config.yaml
